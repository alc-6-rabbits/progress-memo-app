{
  "name": "progress-memo-app",
  "version": "1.4.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "build:electron": "electron-builder build --win"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "nuxt": "^3.11.2",
    "nuxt-electron": "^0.7.0",
    "postcss": "^8.5.6",
    "tailwindcss": "3.4",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "dependencies": {
    "@nuxt/content": "^2.12.1",
    "flatpickr": "^4.6.13",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.0"
  },
  "build": {
    "appId": "com.progress.memo",
    "productName": "Progress Memo",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
